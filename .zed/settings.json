{
  "languages": {
    "TypeScript": {
      "language_servers": [
        "tsgo",
        "oxfmt",
        "oxlint",
        "!vtsls",
        "!typescript-language-server",
      ],
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        { "language_server": { "name": "oxfmt" } },
        { "code_action": "source.fixAll.oxc" },
      ],
    },
    "TSX": {
      "language_servers": [
        "tsgo",
        "oxfmt",
        "oxc",
        "!vtsls",
        "!typescript-language-server",
      ],
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "language_server": { "name": "oxfmt" } },
        { "code_action": "source.fixAll.oxc" },
      ],
    },
    "JavaScript": {
      "format_on_save": "on",
      "prettier": { "allowed": false },
      "formatter": [
        { "language_server": { "name": "oxfmt" } },
        { "code_action": "source.fixAll.oxc" },
      ],
    },
  },
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "disableNestedConfig": false,
          "fixKind": "safe_fix_or_suggestion",
          "run": "onType",
          "unusedDisableDirectives": "deny",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave",
        },
      },
    },
  },
}
